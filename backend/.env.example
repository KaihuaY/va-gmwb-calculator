# AnnuityVoice Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to source control.

# ---------------------------------------------------------------------------
# Email transport for OTP verification
# Priority: SES > SMTP > dev-console fallback (no real email sent)
# ---------------------------------------------------------------------------

# --- Option A: AWS SES (recommended in production on Lambda) ---
# SES_REGION=us-east-1
# FROM_EMAIL=noreply@annuityvoice.com
#   → The "From" address must be verified in SES first.
#   → The Lambda execution role needs ses:SendEmail permission.

# --- Option B: SMTP (works with Gmail, Mailgun, SendGrid, etc.) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-address@gmail.com
# SMTP_PASS=your-app-password        # Gmail: create an App Password in Google Account → Security
# FROM_EMAIL=your-address@gmail.com

# --- Dev / no config ---
#   If neither SES_REGION nor SMTP_HOST is set, the 6-digit OTP is printed
#   to the server console (stderr). Useful for local development without a
#   real email server — just watch the uvicorn output.
